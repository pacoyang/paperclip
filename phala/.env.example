# =============================================================================
# Paperclip - Phala Cloud Environment Variables
# =============================================================================
# Copy to .env and fill in required values before deploying.

# Required
POSTGRES_PASSWORD=changeme
BETTER_AUTH_SECRET=changeme
PAPERCLIP_PUBLIC_URL=https://<your-phala-endpoint>:3100

# Exposure mode: public (default) or private
# PAPERCLIP_DEPLOYMENT_EXPOSURE=public

# Allowed hostnames (for private exposure mode, comma-separated)
# PAPERCLIP_ALLOWED_HOSTNAMES=

# Disable signup after initial setup
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=false

# API Keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Timezone
TZ=UTC
